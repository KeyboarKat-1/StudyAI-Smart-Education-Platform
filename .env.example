# ==============================================================================
# StudyAI Configuration - Environment Variables Example
# Duplicate this file as '.env' in both /backend and /frontend directories,
# or set them at your environment levels.
# ==============================================================================

# ------------------------------------------------------------------------------
# BACKEND SETTINGS (Save as backend/.env)
# ------------------------------------------------------------------------------
PORT=5000
FLASK_ENV=development

# Groq Cloud API - Llama 3.3 Integration
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Firebase Admin SDK Configuration (For cloud database and user verification)
# Leave these blank to automatically run in local fallback mode!
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_CLIENT_EMAIL=your_firebase_service_account_email_here
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# Alternatively, define the path to your Firebase service account JSON file:
# FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json


# ------------------------------------------------------------------------------
# FRONTEND SETTINGS (Save as frontend/.env)
# ------------------------------------------------------------------------------
# API target address
VITE_API_URL=http://127.0.0.1:5000/api

# Firebase Client configuration (For user login and cloud synchronization)
# Leave these blank to run in local fallback mode using mock authentication!
VITE_FIREBASE_API_KEY=your_client_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
